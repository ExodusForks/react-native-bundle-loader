{
  "name": "@exodus/react-native-bundle-loader",
  "version": "0.2.0",
  "description": "Loads a remote React Native JS bundle.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-bundle-loader.podspec",
    "!lib/typescript/example",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ExodusForks/react-native-bundle-loader.git"
  },
  "author": "Exodus Movement, Inc. <hello@exodus.com>",
  "contributors": [
    "Jusbrasil <dev@jusbrasil.com.br> (original author)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ExodusForks/react-native-bundle-loader/issues"
  },
  "homepage": "https://github.com/ExodusForks/react-native-bundle-loader#readme",
  "devDependencies": {
    "@react-native-community/bob": "0.16.2",
    "@react-native-community/eslint-config": "2.0.0",
    "@types/jest": "26.0.14",
    "@types/react": "16.9.52",
    "@types/react-native": "0.62.13",
    "eslint": "7.11.0",
    "eslint-config-prettier": "6.13.0",
    "eslint-plugin-prettier": "3.1.4",
    "jest": "26.5.3",
    "prettier": "2.1.2",
    "react": "16.11.0",
    "react-native": "0.62.2",
    "typescript": "3.9.7"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.62.0"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "eslintConfig": {
    "extends": [
      "@react-native-community",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "@react-native-community/bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
